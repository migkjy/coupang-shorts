{
  "name": "coupang-shorts",
  "version": "1.0.0",
  "description": "쿠팡파트너스 상품 YouTube Shorts/Instagram Reels 자동 생성",
  "scripts": {
    "studio": "npx remotion studio src/index.ts",
    "preview": "npx remotion studio src/index.ts",
    "render": "npx remotion render src/index.ts ShortsTemplate out/video.mp4",
    "typecheck": "tsc --noEmit",
    "fetch": "ts-node scripts/fetch-products.ts",
    "script": "ts-node scripts/generate-script.ts",
    "tts": "ts-node scripts/generate-tts.ts",
    "render-video": "ts-node scripts/render-video.ts",
    "upload": "ts-node scripts/upload-youtube.ts",
    "pipeline": "ts-node scripts/pipeline.ts",
    "pipeline:dry": "ts-node scripts/pipeline.ts --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@remotion/cli": "4.0.290",
    "axios": "^1.7.9",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "googleapis": "^171.4.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "remotion": "4.0.290",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "ts-node": "10.9.2",
    "typescript": "5.3.3"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  }
}
