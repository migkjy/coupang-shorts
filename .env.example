# ──────────────────────────────────────────────────────────────
# 쿠팡파트너스 Open API
# https://developers.coupangcorp.com/hc/en-us/articles/360033917473
# ──────────────────────────────────────────────────────────────
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_PARTNER_ID=

# ──────────────────────────────────────────────────────────────
# Claude AI (스크립트 생성)
# https://console.anthropic.com/settings/keys
# ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────
# TTS (Text-to-Speech)
# TTS_PROVIDER: google 또는 elevenlabs (기본: google)
# ──────────────────────────────────────────────────────────────
TTS_PROVIDER=google

# Google Cloud TTS (무료 월 1M자)
# https://console.cloud.google.com/apis/credentials
GOOGLE_TTS_API_KEY=

# ElevenLabs (더 자연스러운 한국어)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# 음성 ID (기본: pNInz6obpgDQGcFmaJgB — Adam)
# 한국어 지원 음성 목록: https://elevenlabs.io/docs/voices/premade-voices
ELEVENLABS_VOICE_ID=

# ──────────────────────────────────────────────────────────────
# YouTube Data API v3
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
# OAuth2 refresh token 발급: https://developers.google.com/oauthplayground
# ──────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ──────────────────────────────────────────────────────────────
# Late API (클라우드 렌더링)
# https://getlate.dev — 무료 월 20 렌더링
# ──────────────────────────────────────────────────────────────
LATE_API_KEY=
